# ============================================================
# MCR Educational — Environment Variables Example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ----- Next.js -----------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Payload CMS -------------------------------------------
PAYLOAD_SECRET=your-payload-secret-here
PAYLOAD_CONFIG_PATH=src/payload/payload.config.ts

# ----- Database (PostgreSQL via Neon / Supabase) -------------
DATABASE_URI=postgresql://user:password@host:5432/mcr_educational

# ----- File Storage (Cloudflare R2 or AWS S3) ----------------
S3_BUCKET=your-s3-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_REGION=auto
# S3_ENDPOINT format for Cloudflare R2: replace <account-id> with your Cloudflare account ID
# Found at: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ----- Email (Resend) ----------------------------------------
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@mcr-educational.co.uk

# ----- Analytics (Plausible) ---------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mcr-educational.co.uk

# ----- Error Tracking (Sentry) --------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=mcr-educational
